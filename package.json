    "check:all": "bun run lint && bun run format:check && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@react-native/gradle-plugin": "0.84.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  }
}
