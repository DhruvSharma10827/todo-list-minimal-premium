{
  "name": "todo-list",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "bun run --filter '*' lint",
    "format": "bun run --filter '*' format",
    "format:check": "bun run --filter '*' format:check",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "check:all": "bun run lint && bun run format:check && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  }
}
