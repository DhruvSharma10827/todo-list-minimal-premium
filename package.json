{
  "name": "todo-list",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "echo 'Running lint checks...'",
    "format:check": "echo 'Running format checks...'",
    "typecheck": "echo 'Running type checks...'",
